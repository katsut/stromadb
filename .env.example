# StromaDB runtime settings. Read by `stroma-serve` and `stroma-mcp`; a command-line flag
# (--db / --addr) overrides the environment variable, which overrides the built-in default.
# Copy to `.env` and adjust.

# Database directory. `stroma-serve` creates it on first run if it does not exist.
STROMA_DB=./mydb

# HTTP bind address for `stroma-serve`. Default 127.0.0.1:7687 (7687 = the graph-database port
# convention). Use 0.0.0.0:7687 to accept connections from outside the host (e.g. inside Docker).
STROMA_ADDR=127.0.0.1:7687

# Upper bound on the un-merged write backlog (the backpressure threshold + main memory knob).
# Larger = more RAM headroom before backpressure; smaller = backpressure sooner. See docs/CONFIGURATION.md.
STROMA_MAX_UNMERGED=8000000
