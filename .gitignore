# --- Rust ---
/target/
**/target/
**/*.rs.bk
*.pdb
# Cargo.lock IS committed (this workspace ships binaries).

# --- Secrets / env (never commit) ---
.env
.env.*
!.env.example
*.key
*.pem
*.p12
secrets/

# --- Coverage / profiling ---
*.profraw
*.profdata
lcov.info
/coverage/
/criterion/

# --- Local scratch databases ---
# A `stroma init` / `stroma-serve` database directory normally lives outside the repo; ignore the
# common file/dir names so an in-tree scratch DB is not committed by accident.
/db/
/*.wal
wal.log
schema.jsonl
nodes.jsonl
embeddings.bin
embeddings.ids
meta.json
LOCK

# --- OS ---
.DS_Store
.AppleDouble
Thumbs.db
desktop.ini

